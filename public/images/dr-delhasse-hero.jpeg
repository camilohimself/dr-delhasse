/* Formulario de contacto */

.wpforms-form button[type=submit] {
    background-color: #DC1B1A !important;
border-radius: 100px;
Font-family: arial!important;
Font-size: 16px!important;
Font-weight: 600!important;
    color: #f8f8f8 !important;
Padding-left:50px!important;
Padding-right:50px!important;
height:50px!important;
Border-radius:100px!important;
    transition: background 0.3s ease-in-out;
}
 
.wpforms-form button[type=submit]:hover {
    background-color: #153259 !important;
Font-size: 16px !important;
Font-weight: 600 !important;
color: #f8f8f8!important;
}

::-webkit-input-placeholder { /* WebKit browsers */
	font-family: arial;
	font-size: 16px;
	font-weight: 400;
    color: #153259 !important;
    opacity: 1!important;
}

div.wpforms-container-full .wpforms-form input[type=email], div.wpforms-container-full .wpforms-form input[type=tel], div.wpforms-container-full .wpforms-form input[type=text], div.wpforms-container-full .wpforms-form select, div.wpforms-container-full .wpforms-form textarea {
    background-color: #f1f1f1; !important;
    color: #153259 !important;
    max-width: 100% !important;
	border: solid 1px!imporant;
  Border-color:#D9D9D9;
	border-radius: 5px;
	!important;
Height:50px;
	}

div.wpforms-container-full .wpforms-field-file-upload .wpforms-uploader {Background-color:#f1f1f1!important;
max-width: 100% !important;
	border: solid 1px!imporant;
  Border-color:#D9D9D9!important;
	border-radius: 5px!important;
}

.modern-title {Font-family: arial!important;
color:#153259;}

/* input Formulario contacto */

.wpforms-field-container {
    display: flex;
    flex-wrap: wrap;
		justify-content: space-between
}

.ip-100{
		width: 100%!important;
padding-bottom:10px!important;
}
div.wpforms-container-full .wpforms-form input.wpforms-field-medium,
div.wpforms-container-full .wpforms-form select.wpforms-field-medium {
	max-width: 100%;
}
.ip-100 ul {
	display: flex;
	justify-content: space-between;
}

/* Mostrar formulario solo en pantallas móviles */
        @media screen and (max-width: 668px) {

.wpforms-form button[type=submit] {
Font-size: 15px !important;
Padding-left:40px!important;
Padding-right:40px!important;
height:45px!important;
Border-radius:100px!important;
    transition: background 0.3s ease-in-out;
}
 
.wpforms-form button[type=submit]:hover {
    background-color: #FF5F00 !important;
Font-size: 15px !important;
Font-weight: 500 !important;
color: #f8f8f8!important;
}

::-webkit-input-placeholder { /* WebKit browsers */
	font-size: 15px;
    color: #153259 !important;
    opacity: 0.8!important;
}

    .wpforms-field-container {
    display: flex;
    flex-wrap: wrap;
		justify-content: space-between
}
.ip-50 {
    width: 100%!important;
padding-bottom:5px!important;
}
.ip-100{
		width: 100%!important;
padding-bottom:5px!important;

}

