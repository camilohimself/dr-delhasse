---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: 'fr' | 'en' | 'de';
  alternates?: { fr: string; en: string; de: string };
}

const { title, description = 'Dr. Sébastien Delhasse — Cardiologue FMH en Valais. Consultations en cardiologie et médecine interne à Saxon.', lang = 'fr', alternates } = Astro.props;

const htmlLang = lang === 'fr' ? 'fr-CH' : lang === 'en' ? 'en' : 'de-CH';
const prefix = lang === 'fr' ? '' : `/${lang}`;
const contactHref = lang === 'fr' ? '/contact' : lang === 'en' ? '/en/contact' : '/de/kontakt';
const ctaLabel = lang === 'fr' ? 'Prendre rendez-vous' : lang === 'en' ? 'Book appointment' : 'Termin vereinbaren';

// Dynamic canonical + hreflang
const siteUrl = 'https://drdelhasse-cardiologue.ch';
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '';
const canonicalUrl = `${siteUrl}${currentPath}`;

// Build hreflang URLs — use alternates prop if provided (for sub-pages with different slugs)
const hreflangFr = alternates ? `${siteUrl}${alternates.fr}` : `${siteUrl}${currentPath.replace(/^\/(en|de)/, '') || '/'}`;
const hreflangEn = alternates ? `${siteUrl}${alternates.en}` : `${siteUrl}/en${currentPath.replace(/^\/(en|de)/, '') || '/'}`;
const hreflangDe = alternates ? `${siteUrl}${alternates.de}` : `${siteUrl}/de${currentPath.replace(/^\/(en|de)/, '') || '/'}`;

// Localized structured data description
const structuredDescriptions = {
  fr: 'Cardiologue FMH et spécialiste en médecine interne, consultations à la Clinique CIC de Saxon, Valais.',
  en: 'FMH cardiologist and internal medicine specialist, consultations at the CIC Clinic in Saxon, Valais.',
  de: 'FMH-Kardiologe und Facharzt für Innere Medizin, Sprechstunden in der Klinik CIC Saxon, Wallis.',
};

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Physician",
  "name": "Dr. Sébastien Delhasse",
  "description": structuredDescriptions[lang],
  "url": "https://drdelhasse-cardiologue.ch",
  "telephone": "+41277434059",
  "email": "sebastien.delhasse@hotmail.com",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Rte du Léman 29",
    "addressLocality": "Saxon",
    "postalCode": "1907",
    "addressRegion": "Valais",
    "addressCountry": "CH"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 46.1467,
    "longitude": 7.1847
  },
  "medicalSpecialty": "Cardiology",
  "availableLanguage": ["French", "English", "German"],
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
    "opens": "09:00",
    "closes": "17:00"
  },
  "image": "https://drdelhasse-cardiologue.ch/images/dr-delhasse.jpeg",
  "sameAs": []
};
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/images/red-iso.png" />
    <title>{title}</title>

    <!-- Inter font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Preload critical images -->
    <link rel="preload" as="image" href="/images/logo-without-background.png" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={htmlLang} />
    <meta property="og:image" content="https://drdelhasse-cardiologue.ch/images/dr-delhasse.jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Dr. Sébastien Delhasse — Cardiologue FMH" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://drdelhasse-cardiologue.ch/images/dr-delhasse.jpeg" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Hreflang (dynamic per page) -->
    <link rel="alternate" hreflang="fr" href={hreflangFr} />
    <link rel="alternate" hreflang="en" href={hreflangEn} />
    <link rel="alternate" hreflang="de" href={hreflangDe} />
    <link rel="alternate" hreflang="x-default" href={hreflangFr} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <!-- Skip link -->
    <a href="#main-content" class="skip-link">
      {lang === 'fr' ? 'Aller au contenu' : lang === 'en' ? 'Skip to content' : 'Zum Inhalt springen'}
    </a>

    <Header lang={lang} />
    <main class="main" id="main-content">
      <slot />
    </main>
    <Footer lang={lang} />
    <CookieConsent lang={lang} />

    <!-- Floating CTA + Back to top -->
    <div class="floating-cta">
      <a href={contactHref} class="floating-cta__btn" id="floating-cta">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
        {ctaLabel}
      </a>
      <button class="back-to-top" id="back-to-top" aria-label={lang === 'fr' ? 'Retour en haut' : lang === 'en' ? 'Back to top' : 'Nach oben'}>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
      </button>
    </div>

    <!-- Reveal animations + Floating CTA logic -->
    <script>
      // Reveal on scroll
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

      document.querySelectorAll('.section, .card, .process__card, .service-card, .hub-card, .formation-card, .cta-card, .engagement-card, .contact-card').forEach((el) => {
        el.classList.add('reveal');
        observer.observe(el);
      });

      // Floating CTA + Back to top visibility
      const floatingCta = document.getElementById('floating-cta');
      const backToTop = document.getElementById('back-to-top');

      const toggleFloating = () => {
        const scrolled = window.scrollY > 400;
        floatingCta?.classList.toggle('visible', scrolled);
        backToTop?.classList.toggle('visible', scrolled);
      };

      window.addEventListener('scroll', toggleFloating, { passive: true });
      toggleFloating();

      backToTop?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    </script>
  </body>
</html>

<style>
  .main {
    margin-top: var(--header-total);
  }
</style>
