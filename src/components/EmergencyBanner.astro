---
interface Props {
  lang?: 'fr' | 'en' | 'de';
}

const { lang = 'fr' } = Astro.props;

const text = {
  fr: { label: 'Urgence cardiaque ?', action: 'Appelez le 144', sub: 'Service ambulancier suisse — 24h/24' },
  en: { label: 'Cardiac emergency?', action: 'Call 144', sub: 'Swiss ambulance service — 24/7' },
  de: { label: 'Herznotfall?', action: 'Rufen Sie 144 an', sub: 'Schweizer Rettungsdienst — rund um die Uhr' },
};

const t = text[lang];
---

<div class="emergency-banner">
  <div class="container emergency-banner__inner">
    <div class="emergency-banner__text">
      <strong>{t.label}</strong>
      <span>{t.sub}</span>
    </div>
    <a href="tel:144" class="emergency-banner__btn">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      {t.action}
    </a>
  </div>
</div>

<style>
  .emergency-banner {
    background: linear-gradient(135deg, #b81615 0%, #DC1B1A 100%);
    padding: 1rem 0;
    margin-top: -1px;
  }

  .emergency-banner__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .emergency-banner__text {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .emergency-banner__text strong {
    color: var(--color-white);
    font-size: 1rem;
  }

  .emergency-banner__text span {
    color: rgba(255, 255, 255, 0.95);
    font-size: 0.85rem;
  }

  .emergency-banner__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.25rem;
    background: var(--color-white);
    color: var(--color-primary);
    border-radius: 50px;
    font-weight: 700;
    font-size: 0.95rem;
    transition: all 0.2s ease;
  }

  .emergency-banner__btn:hover {
    transform: scale(1.05);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
  }

  @media (max-width: 768px) {
    .emergency-banner__inner {
      justify-content: center;
      text-align: center;
    }
  }
</style>
