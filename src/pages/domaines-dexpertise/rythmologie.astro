<DetailLayout
  title="Rythmologie — Troubles du rythme cardiaque — Dr Delhasse"
  description="Diagnostic et traitement des troubles du rythme cardiaque : bradycardie, tachycardie, fibrillation auriculaire. Dr Delhasse, cardiologue FMH."
  lang="fr"
  alternates={{ fr: '/domaines-dexpertise/rythmologie', en: '/en/areas-of-expertise/rhythmology', de: '/de/fachgebiete/rhythmologie' }}
