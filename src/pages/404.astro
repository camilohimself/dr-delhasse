---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page introuvable — Dr Delhasse" description="La page demandée n'existe pas ou a été déplacée." lang="fr">

  <section class="error-hero">
    <div class="container error-hero__content">
      <p class="error-hero__code">404</p>
      <h1>Page <span class="text-primary">introuvable</span></h1>
      <p class="error-hero__sub">La page que vous cherchez n'existe pas ou a été déplacée.</p>

      <div class="error-hero__actions">
        <a href="/" class="btn btn--primary">Retour à l'accueil</a>
        <a href="/contact" class="btn btn--outline">Contactez-nous</a>
      </div>

      <div class="error-hero__links">
        <p>Vous cherchiez peut-être :</p>
        <ul>
          <li><a href="/symptomes">Symptômes cardiaques</a></li>
          <li><a href="/domaines-dexpertise">Domaines d'expertise</a></li>
          <li><a href="/examens-cardiologiques">Examens cardiologiques</a></li>
          <li><a href="/a-propos">À propos du Dr Delhasse</a></li>
        </ul>
      </div>
    </div>
  </section>

</Layout>

<style>
  .error-hero {
    background: linear-gradient(135deg, var(--color-navy) 0%, #0e2240 50%, #1a3d6d 100%);
    padding: 8rem 0 6rem;
    color: var(--color-white);
    min-height: 70vh;
    display: flex;
    align-items: center;
  }

  .error-hero__content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .error-hero__code {
    font-size: 8rem;
    font-weight: 800;
    line-height: 1;
    color: var(--color-primary);
    opacity: 0.3;
    margin-bottom: 0.5rem;
  }

  .error-hero h1 {
    color: var(--color-white);
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .error-hero__sub {
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.15rem;
    margin-bottom: 2.5rem;
  }

  .error-hero__actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .error-hero__links {
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    padding-top: 2rem;
  }

  .error-hero__links p {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .error-hero__links ul {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
    list-style: none;
    padding: 0;
  }

  .error-hero__links a {
    color: rgba(255, 255, 255, 0.75);
    font-size: 0.9rem;
    transition: color 0.2s ease;
  }

  .error-hero__links a:hover {
    color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .error-hero { padding: 6rem 0 4rem; }
    .error-hero__code { font-size: 5rem; }
    .error-hero h1 { font-size: 1.75rem; }
    .error-hero__links ul { flex-direction: column; gap: 0.75rem; }
  }
</style>
