---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Collaboration médicale — Référer un patient — Dr Delhasse" description="Collaboration médicale : référez un patient au Dr Delhasse, cardiologue FMH à la Clinique CIC de Saxon." lang="fr">

  <section class="hero-page">
    <div class="container">
      <h1>Collaboration <span class="text-primary">médicale</span></h1>
      <p class="hero-sub">Référer un patient au Dr Delhasse</p>
    </div>
  </section>

  <section class="section">
    <div class="container form-container">
      <nav class="form-tabs">
        <a href="/demande-de-rdv" class="form-tab">Rendez-vous</a>
        <a href="/question-medicale-simple" class="form-tab">Question médicale</a>
        <a href="/collaboration-ou-autre" class="form-tab active">Collaboration</a>
      </nav>

      <form name="collaboration" id="contact-form" method="POST" action="mailto:sebastien.delhasse@hotmail.com" enctype="text/plain" class="contact-form">
        <div class="form-grid">
          <div class="form-group">
            <label for="prenom">Prénom</label>
            <input type="text" id="prenom" name="prenom" />
          </div>
          <div class="form-group">
            <label for="nom">Nom <span class="required">*</span></label>
            <input type="text" id="nom" name="nom" required />
          </div>
        </div>
        <div class="form-group">
          <label for="email">Adresse mail</label>
          <input type="email" id="email" name="email" />
        </div>
        <div class="form-group">
          <label for="sujet">Sujet</label>
          <input type="text" id="sujet" name="sujet" />
        </div>
        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="6"></textarea>
        </div>
        <button type="submit" class="btn btn--primary">Envoyer</button>
      </form>
    </div>
  </section>

</Layout>

<style>
  .hero-page { background: linear-gradient(135deg, var(--color-navy) 0%, #1a3d6d 100%); padding: 6rem 0 4rem; color: var(--color-white); }
  .hero-page h1 { color: var(--color-white); font-size: 2.75rem; }
  .hero-sub { color: rgba(255,255,255,0.75); font-size: 1.15rem; margin-top: 1rem; }
  .form-container { max-width: 700px; }
  .form-tabs { display: flex; gap: 0; margin-bottom: 2rem; border-bottom: 2px solid var(--color-gray-light); }
  .form-tab { padding: 0.75rem 1.5rem; text-decoration: none; color: var(--color-gray); font-weight: 600; border-bottom: 2px solid transparent; margin-bottom: -2px; transition: all 0.3s; }
  .form-tab:hover, .form-tab.active { color: var(--color-primary); border-bottom-color: var(--color-primary); }
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-group { margin-bottom: 1.25rem; }
  .form-group label { display: block; margin-bottom: 0.5rem; font-weight: 600; font-size: 0.9rem; color: var(--color-navy); }
  .form-group input, .form-group textarea { width: 100%; padding: 0.75rem 1rem; border: 1px solid #ddd; border-radius: 6px; font-size: 0.95rem; transition: border-color 0.3s; }
  .form-group input:focus, .form-group textarea:focus { border-color: var(--color-primary); box-shadow: 0 0 0 3px rgba(220, 27, 26, 0.12); outline: 2px solid transparent; }
  .required { color: var(--color-primary); }
  @media (max-width: 768px) { .form-grid { grid-template-columns: 1fr; } .hero-page h1 { font-size: 2rem; } .form-tabs { flex-wrap: wrap; } .form-tab { font-size: 0.85rem; padding: 0.5rem 1rem; } }
</style>
