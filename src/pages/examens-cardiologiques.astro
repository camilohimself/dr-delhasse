---
import Layout from '../layouts/Layout.astro';

const examens = [
  { title: 'Électrocardiogramme (ECG)', icon: '/images/svg/examens/Electrocardiogramme.svg', text: "Un examen rapide et indolore qui en dit long sur l'activité électrique de votre cœur. Découvrez ce qu'un simple ECG peut révéler.", href: '/examens-cardiologiques/electrocardiogramme' },
  { title: 'Échocardiographie', icon: '/images/svg/examens/Ecocardiografia.svg', text: "Voir son propre cœur battre en direct. L'échocardiographie, ou ultrasons du cœur, est une fenêtre ouverte sur sa structure et sa fonction de pompage.", href: '/examens-cardiologiques/echocardiographie' },
  { title: 'Ergométrie', icon: '/images/svg/examens/Ergometria.svg', text: "Comment votre cœur réagit-il à l'effort ? Le test d'effort sur vélo permet de déceler des anomalies qui n'apparaissent qu'en situation de stress.", href: '/examens-cardiologiques/ergometrie' },
  { title: 'Stimulateur cardiaque', icon: '/images/svg/examens/Marcapasos.svg', text: "Quand le rythme cardiaque est trop lent ou dangereusement rapide, des dispositifs implantables modernes peuvent prendre le relais pour protéger votre cœur.", href: '/examens-cardiologiques/stimulateur-cardiaque' },
  { title: 'Laboratoire', icon: '/images/svg/examens/Laboratorio.svg', text: "Une simple prise de sang peut révéler des informations cruciales sur votre santé cardiovasculaire, des facteurs de risque aux marqueurs d'une souffrance cardiaque.", href: '/examens-cardiologiques/laboratoire' },
  { title: 'IRM cardiaque', icon: '/images/svg/examens/Resonancia-magnetica.svg', text: "L'imagerie de pointe pour une vision d'une précision inégalée. Découvrez quand l'IRM cardiaque est utilisée pour analyser en détail le muscle du cœur.", href: '/examens-cardiologiques/irm-cardiaque' },
  { title: 'Holter et R-test', icon: '/images/svg/examens/Holter-y-prueba.svg', text: "Certains troubles du rythme sont discrets et intermittents. Le Holter ou le R-Test permettent de les « capturer » sur 24h ou plus pour un diagnostic précis.", href: '/examens-cardiologiques/holter-et-r-test' },
];
---

<Layout title="Examens cardiologiques — Suivi à Sion" description="ECG, échocardiographie, ergométrie, IRM cardiaque, Holter : découvrez les examens cardiologiques proposés par le Dr Delhasse." lang="fr">

  <section class="hero-page">
    <div class="hero-page__bg" aria-hidden="true"></div>
    <div class="container hero-page__content">
      <p class="hero-page__label">Le Cœur & vous</p>
      <h1>Examens <span class="text-primary">cardiologiques</span></h1>
      <p class="hero-page__sub">Des technologies de pointe au service de votre diagnostic</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="card-grid">
        {examens.map((e) => (
          <a href={e.href} class="card">
            <div class="card__icon-wrap">
              <img src={e.icon} alt={e.title} class="card__icon" loading="lazy" width="40" height="40" />
            </div>
            <h3 class="card__title">{e.title}</h3>
            <p class="card__text">{e.text}</p>
            <span class="card__link">
              En savoir plus
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 16 16 12 12 8"/><line x1="8" x2="16" y1="12" y2="12"/></svg>
            </span>
          </a>
        ))}
      </div>

      <div class="cta-banner">
        <div class="cta-banner__text">
          <h2>Un examen à planifier ?</h2>
          <p>Contactez-nous pour un bilan cardiologique complet.</p>
        </div>
        <a href="/contact" class="btn btn--primary">Prendre rendez-vous</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .hero-page { background: linear-gradient(135deg, var(--color-navy) 0%, #0e2240 50%, #1a3d6d 100%); padding: 7rem 0 4rem; color: var(--color-white); position: relative; overflow: hidden; }
  .hero-page__bg { position: absolute; inset: 0; background-image: url('/images/coeur-raisons.webp'); background-size: cover; background-position: center; opacity: 0.12; }
  .hero-page__content { position: relative; z-index: 2; }
  .hero-page__label { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 2px; color: var(--color-primary); font-weight: 600; margin-bottom: 0.75rem; }
  .hero-page h1 { color: var(--color-white); font-size: 3rem; margin-bottom: 0.75rem; }
  .hero-page__sub { color: rgba(255, 255, 255, 0.7); font-size: 1.1rem; max-width: 500px; }
  .card-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
  .card { display: flex; flex-direction: column; background: var(--color-white); border-radius: var(--radius-md); padding: 2rem; box-shadow: var(--shadow-sm); transition: all 0.3s ease; text-decoration: none; border: 1px solid transparent; }
  .card:hover { transform: translateY(-6px); box-shadow: var(--shadow-lg); border-color: rgba(220, 27, 26, 0.15); }
  .card__icon-wrap { width: 72px; height: 72px; background: var(--color-gray-light); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; margin-bottom: 1.25rem; transition: all 0.3s ease; }
  .card:hover .card__icon-wrap { background: var(--color-primary-light); }
  .card__icon { width: 40px; height: 40px; }
  .card__title { font-size: 1.1rem; margin-bottom: 0.75rem; text-transform: uppercase; letter-spacing: 0.3px; font-weight: 700; }
  .card__text { font-size: 0.9rem; line-height: 1.6; color: var(--color-gray); flex: 1; }
  .card__link { display: inline-flex; align-items: center; gap: 0.5rem; margin-top: 1.25rem; padding: 0.5rem 1rem; background: var(--color-primary); color: var(--color-white); border-radius: 50px; font-size: 0.8rem; font-weight: 600; transition: all 0.3s ease; align-self: flex-start; }
  .card:hover .card__link { background: var(--color-primary-dark); transform: translateX(4px); }
  .cta-banner { margin-top: 4rem; background: var(--color-navy); border-radius: var(--radius-lg); padding: 3rem; display: flex; align-items: center; justify-content: space-between; gap: 2rem; }
  .cta-banner h2 { color: var(--color-white); font-size: 1.5rem; margin-bottom: 0.5rem; }
  .cta-banner p { color: rgba(255, 255, 255, 0.7); margin: 0; font-size: 0.95rem; }
  @media (max-width: 1024px) { .card-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) { .hero-page h1 { font-size: 2.25rem; } .card-grid { grid-template-columns: 1fr; } .cta-banner { flex-direction: column; text-align: center; padding: 2rem; } }
</style>
