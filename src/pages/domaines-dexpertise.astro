---
import Layout from '../layouts/Layout.astro';

const domaines = [
  { title: 'Rythmologie', icon: '/images/svg/expertise/Rythmologie.svg', text: "Du simple trouble du rythme aux pathologies complexes. Explorez notre expertise dans le diagnostic et le traitement de l'activité électrique du cœur.", href: '/domaines-dexpertise/rythmologie' },
  { title: 'Maladies valvulaires', icon: '/images/svg/expertise/Maladie-valvulaires.svg', text: "Sténose ou insuffisance, vos valves cardiaques sont au cœur de notre attention. Découvrez les solutions modernes, de la surveillance aux interventions de pointe.", href: '/domaines-dexpertise/maladie-valvulaires' },
  { title: 'Prévention', icon: '/images/svg/expertise/prevention.svg', text: "Le meilleur traitement est celui que l'on évite. Apprenez à maîtriser vos facteurs de risque (cholestérol, tension) pour protéger votre avenir cardiovasculaire.", href: '/domaines-dexpertise/prevention' },
  { title: 'Hypertension artérielle', icon: '/images/svg/expertise/Hypertension-arterielle.svg', text: "Souvent silencieuse, l'hypertension endommage vos artères. Une prise en charge spécialisée est essentielle pour contrôler votre tension et protéger vos organes.", href: '/domaines-dexpertise/hypertension-arterielle' },
  { title: 'Maladie coronarienne', icon: '/images/svg/expertise/Maladie-coronarienne.svg', text: "L'angine de poitrine est le signal d'alarme de vos artères. Comprenez cette maladie pour agir avant qu'elle ne mène à des complications plus graves.", href: '/domaines-dexpertise/maladie-coronarienne' },
  { title: 'Suivi après infarctus', icon: '/images/svg/expertise/Suivi-apres-infarctus.svg', text: "Survivre à un infarctus est la première étape. Découvrez l'importance d'un suivi personnalisé pour une récupération optimale et la prévention des récidives.", href: '/domaines-dexpertise/suivi-apres-infarctus' },
  { title: 'Insuffisance cardiaque', icon: '/images/svg/expertise/Insuffisance-cardiaque.svg', text: "Lorsque le cœur fatigue, chaque détail compte. Explorez les approches modernes pour gérer l'insuffisance cardiaque et améliorer votre qualité de vie.", href: '/domaines-dexpertise/insuffisance-cardiaque' },
  { title: 'Bilan préopératoire', icon: '/images/svg/expertise/Bilan-preoperatoire.svg', text: "Toute chirurgie est un stress pour le cœur. Notre évaluation préopératoire vise à garantir votre sécurité, quelle que soit l'intervention prévue.", href: '/domaines-dexpertise/bilan-preoperatoire' },
  { title: 'Cardiomyopathies', icon: '/images/svg/expertise/Cardiomyopathies.svg', text: "Les maladies du muscle cardiaque sont complexes et souvent d'origine génétique. Découvrez comment un diagnostic précis est la clé d'une prise en charge efficace.", href: '/domaines-dexpertise/cardiomyopathies' },
  { title: 'Évaluation sportive', icon: '/images/svg/expertise/Evaluation-a-la-pratique-sportive.svg', text: "Sportif amateur ou confirmé ? Une évaluation cardiologique vous permet de pratiquer votre passion en toute sécurité et d'optimiser vos performances.", href: '/domaines-dexpertise/evaluation-a-la-pratique-sportive' },
];
---

<Layout title="Domaines d'expertise — Cardiologie en Valais" description="Rythmologie, prévention, hypertension, maladies coronariennes, insuffisance cardiaque et plus. Dr Delhasse, cardiologue FMH." lang="fr">

  <section class="hero-page">
    <div class="hero-page__bg" aria-hidden="true"></div>
    <div class="container hero-page__content">
      <p class="hero-page__label">Le Cœur & vous</p>
      <h1>Domaines d'<span class="text-primary">expertise</span></h1>
      <p class="hero-page__sub">Une prise en charge globale de votre santé cardiovasculaire</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="card-grid">
        {domaines.map((d) => (
          <a href={d.href} class="card">
            <div class="card__icon-wrap">
              <img src={d.icon} alt={d.title} class="card__icon" loading="lazy" width="40" height="40" />
            </div>
            <h3 class="card__title">{d.title}</h3>
            <p class="card__text">{d.text}</p>
            <span class="card__link">
              En savoir plus
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 16 16 12 12 8"/><line x1="8" x2="16" y1="12" y2="12"/></svg>
            </span>
          </a>
        ))}
      </div>

      <div class="cta-banner">
        <div class="cta-banner__text">
          <h2>Besoin d'un avis spécialisé ?</h2>
          <p>Prenez rendez-vous pour une consultation cardiologique complète.</p>
        </div>
        <a href="/contact" class="btn btn--primary">Prendre rendez-vous</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .hero-page { background: linear-gradient(135deg, var(--color-navy) 0%, #0e2240 50%, #1a3d6d 100%); padding: 7rem 0 4rem; color: var(--color-white); position: relative; overflow: hidden; }
  .hero-page__bg { position: absolute; inset: 0; background-image: url('/images/accompagnement.webp'); background-size: cover; background-position: center; opacity: 0.12; }
  .hero-page__content { position: relative; z-index: 2; }
  .hero-page__label { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 2px; color: var(--color-primary); font-weight: 600; margin-bottom: 0.75rem; }
  .hero-page h1 { color: var(--color-white); font-size: 3rem; margin-bottom: 0.75rem; }
  .hero-page__sub { color: rgba(255, 255, 255, 0.7); font-size: 1.1rem; max-width: 500px; }
  .card-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
  .card { display: flex; flex-direction: column; background: var(--color-white); border-radius: var(--radius-md); padding: 2rem; box-shadow: var(--shadow-sm); transition: all 0.3s ease; text-decoration: none; border: 1px solid transparent; }
  .card:hover { transform: translateY(-6px); box-shadow: var(--shadow-lg); border-color: rgba(220, 27, 26, 0.15); }
  .card__icon-wrap { width: 72px; height: 72px; background: var(--color-gray-light); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; margin-bottom: 1.25rem; transition: all 0.3s ease; }
  .card:hover .card__icon-wrap { background: var(--color-primary-light); }
  .card__icon { width: 40px; height: 40px; }
  .card__title { font-size: 1.1rem; margin-bottom: 0.75rem; text-transform: uppercase; letter-spacing: 0.3px; font-weight: 700; }
  .card__text { font-size: 0.9rem; line-height: 1.6; color: var(--color-gray); flex: 1; }
  .card__link { display: inline-flex; align-items: center; gap: 0.5rem; margin-top: 1.25rem; padding: 0.5rem 1rem; background: var(--color-primary); color: var(--color-white); border-radius: 50px; font-size: 0.8rem; font-weight: 600; transition: all 0.3s ease; align-self: flex-start; }
  .card:hover .card__link { background: var(--color-primary-dark); transform: translateX(4px); }
  .cta-banner { margin-top: 4rem; background: var(--color-navy); border-radius: var(--radius-lg); padding: 3rem; display: flex; align-items: center; justify-content: space-between; gap: 2rem; }
  .cta-banner h2 { color: var(--color-white); font-size: 1.5rem; margin-bottom: 0.5rem; }
  .cta-banner p { color: rgba(255, 255, 255, 0.7); margin: 0; font-size: 0.95rem; }
  @media (max-width: 1024px) { .card-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) { .hero-page h1 { font-size: 2.25rem; } .card-grid { grid-template-columns: 1fr; } .cta-banner { flex-direction: column; text-align: center; padding: 2rem; } }
</style>
