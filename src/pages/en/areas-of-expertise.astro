---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const areas = [
  { title: 'Rhythmology', icon: '/images/svg/expertise/Rythmologie.svg', text: 'From simple rhythm disorders to complex conditions. Explore our expertise in diagnosing and treating the electrical activity of the heart.' },
  { title: 'Valvular diseases', icon: '/images/svg/expertise/Maladie-valvulaires.svg', text: 'Stenosis or insufficiency — your heart valves are at the centre of our attention. Discover modern solutions, from monitoring to cutting-edge interventions.' },
  { title: 'Prevention', icon: '/images/svg/expertise/prevention.svg', text: 'The best treatment is the one you avoid. Learn to control your risk factors (cholesterol, blood pressure) to protect your cardiovascular future.' },
  { title: 'Arterial hypertension', icon: '/images/svg/expertise/Hypertension-arterielle.svg', text: 'Often silent, hypertension damages your arteries. Specialised management is essential to control your blood pressure and protect your organs.' },
  { title: 'Coronary artery disease', icon: '/images/svg/expertise/Maladie-coronarienne.svg', text: 'Angina is the alarm signal from your arteries. Understand this disease to act before it leads to more serious complications.' },
  { title: 'Post-infarction follow-up', icon: '/images/svg/expertise/Suivi-apres-infarctus.svg', text: 'Surviving a heart attack is the first step. Discover the importance of personalised follow-up for optimal recovery and recurrence prevention.' },
  { title: 'Heart failure', icon: '/images/svg/expertise/Insuffisance-cardiaque.svg', text: 'When the heart tires, every detail matters. Explore modern approaches to managing heart failure and improving your quality of life.' },
  { title: 'Pre-operative assessment', icon: '/images/svg/expertise/Bilan-preoperatoire.svg', text: 'Every surgery is a stress on the heart. Our pre-operative evaluation aims to ensure your safety, whatever the planned procedure.' },
  { title: 'Cardiomyopathies', icon: '/images/svg/expertise/Cardiomyopathies.svg', text: 'Heart muscle diseases are complex and often genetic. Discover how a precise diagnosis is the key to effective management.' },
  { title: 'Sports fitness assessment', icon: '/images/svg/expertise/Evaluation-a-la-pratique-sportive.svg', text: 'Amateur or seasoned athlete? A cardiological assessment lets you practise your passion safely and optimise your performance.' },
];
---

<Layout title="Areas of Expertise — Cardiology in Valais" description="Rhythmology, prevention, hypertension, coronary disease, heart failure and more. Dr Delhasse, FMH cardiologist." lang="en">

  <section class="hero-page">
    <div class="container">
      <Breadcrumb items={[{label:'Home', href:'/en'}, {label:'Areas of Expertise'}]} />
      <h1>Areas of <span class="text-primary">Expertise</span></h1>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="card-grid">
        {areas.map((d) => (
          <div class="card">
            <img src={d.icon} alt={d.title} class="card__icon" loading="lazy" />
            <h3>{d.title}</h3>
            <p>{d.text}</p>
          </div>
        ))}
      </div>
      <div class="text-center" style="margin-top: 3rem;">
        <a href="/en/contact" class="btn btn--primary">Book an appointment</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .hero-page { background: linear-gradient(135deg, var(--color-navy) 0%, #1a3d6d 100%); padding: 6rem 0 4rem; color: var(--color-white); }
  .hero-page h1 { color: var(--color-white); font-size: 2.75rem; }
  .card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2rem; }
  .card { background: var(--color-white); border-radius: 8px; padding: 2rem; box-shadow: 0 2px 12px rgba(0,0,0,0.06); transition: all 0.3s ease; border-left: 3px solid transparent; }
  .card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.1); border-left-color: var(--color-primary); }
  .card__icon { width: 56px; height: 56px; margin-bottom: 1.25rem; }
  .card h3 { margin-bottom: 0.75rem; font-size: 1.15rem; }
  .card p { font-size: 0.95rem; line-height: 1.6; }
</style>
