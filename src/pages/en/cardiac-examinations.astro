---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const exams = [
  { title: 'Electrocardiogram (ECG)', icon: '/images/svg/examens/Electrocardiogramme.svg', text: "A quick, painless examination that reveals a great deal about the electrical activity of your heart.", href: '/en/cardiac-examinations/electrocardiogram' },
  { title: 'Echocardiography', icon: '/images/svg/examens/Ecocardiografia.svg', text: "Watching your own heart beat in real time. Echocardiography is a window onto its structure and pumping function.", href: '/en/cardiac-examinations/echocardiography' },
  { title: 'Exercise testing', icon: '/images/svg/examens/Ergometria.svg', text: "How does your heart respond to exertion? The bicycle stress test can detect abnormalities that only appear under physical stress.", href: '/en/cardiac-examinations/exercise-stress-test' },
  { title: 'Pacemaker', icon: '/images/svg/examens/Marcapasos.svg', text: "When the heartbeat is too slow or dangerously fast, modern implantable devices can take over to protect your heart.", href: '/en/cardiac-examinations/pacemaker-defibrillator' },
  { title: 'Laboratory', icon: '/images/svg/examens/Laboratorio.svg', text: "A simple blood test can reveal crucial information about your cardiovascular health, from risk factors to markers of cardiac distress.", href: '/en/cardiac-examinations/laboratory' },
  { title: 'Cardiac MRI', icon: '/images/svg/examens/Resonancia-magnetica.svg', text: "Cutting-edge imaging for unrivalled precision. Discover when cardiac MRI is used to analyse the heart muscle in detail.", href: '/en/cardiac-examinations/cardiac-mri' },
  { title: 'Holter and R-test', icon: '/images/svg/examens/Holter-y-prueba.svg', text: "Some rhythm disorders are subtle and intermittent. The Holter monitor or R-Test captures them over 24 hours or more.", href: '/en/cardiac-examinations/holter-and-r-test' },
];
---

<Layout title="Cardiac Examinations — Follow-up in Sion" description="ECG, echocardiography, exercise testing, cardiac MRI, Holter: discover the cardiac examinations offered by Dr Delhasse." lang="en">

  <section class="hero-page">
    <div class="hero-page__bg" aria-hidden="true"></div>
    <div class="container hero-page__content">
      <p class="hero-page__label">Heart & You</p>
      <h1>Cardiac <span class="text-primary">Examinations</span></h1>
      <p class="hero-page__sub">Cutting-edge technology at the service of your diagnosis</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="card-grid">
        {exams.map((e) => (
          <a href={e.href} class="card">
            <div class="card__icon-wrap">
              <img src={e.icon} alt={e.title} class="card__icon" loading="lazy" />
            </div>
            <h3 class="card__title">{e.title}</h3>
            <p class="card__text">{e.text}</p>
            <span class="card__link">Learn more <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 16 16 12 12 8"/><line x1="8" x2="16" y1="12" y2="12"/></svg></span>
          </a>
        ))}
      </div>
      <div class="cta-banner">
        <div class="cta-banner__text"><h2>Need an examination?</h2><p>Contact us for a comprehensive cardiac assessment.</p></div>
        <a href="/en/contact" class="btn btn--primary">Book an appointment</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .hero-page { background: linear-gradient(135deg, var(--color-navy) 0%, #0e2240 50%, #1a3d6d 100%); padding: 7rem 0 4rem; color: var(--color-white); position: relative; overflow: hidden; }
  .hero-page__bg { position: absolute; inset: 0; background-image: url('/images/coeur-raisons.webp'); background-size: cover; background-position: center; opacity: 0.12; }
  .hero-page__content { position: relative; z-index: 2; }
  .hero-page__label { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 2px; color: var(--color-primary); font-weight: 600; margin-bottom: 0.75rem; }
  .hero-page h1 { color: var(--color-white); font-size: 3rem; margin-bottom: 0.75rem; }
  .hero-page__sub { color: rgba(255, 255, 255, 0.7); font-size: 1.1rem; max-width: 500px; }
  .card-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
  .card { display: flex; flex-direction: column; background: var(--color-white); border-radius: var(--radius-md); padding: 2rem; box-shadow: var(--shadow-sm); transition: all 0.3s ease; text-decoration: none; border: 1px solid transparent; }
  .card:hover { transform: translateY(-6px); box-shadow: var(--shadow-lg); border-color: rgba(220, 27, 26, 0.15); }
  .card__icon-wrap { width: 72px; height: 72px; background: var(--color-gray-light); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; margin-bottom: 1.25rem; transition: all 0.3s ease; }
  .card:hover .card__icon-wrap { background: var(--color-primary-light); }
  .card__icon { width: 40px; height: 40px; }
  .card__title { font-size: 1.1rem; margin-bottom: 0.75rem; text-transform: uppercase; letter-spacing: 0.3px; font-weight: 700; }
  .card__text { font-size: 0.9rem; line-height: 1.6; color: var(--color-gray); flex: 1; }
  .card__link { display: inline-flex; align-items: center; gap: 0.5rem; margin-top: 1.25rem; padding: 0.5rem 1rem; background: var(--color-primary); color: var(--color-white); border-radius: 50px; font-size: 0.8rem; font-weight: 600; transition: all 0.3s ease; align-self: flex-start; }
  .card:hover .card__link { background: var(--color-primary-dark); transform: translateX(4px); }
  .cta-banner { margin-top: 4rem; background: var(--color-navy); border-radius: var(--radius-lg); padding: 3rem; display: flex; align-items: center; justify-content: space-between; gap: 2rem; }
  .cta-banner h2 { color: var(--color-white); font-size: 1.5rem; margin-bottom: 0.5rem; }
  .cta-banner p { color: rgba(255, 255, 255, 0.7); margin: 0; font-size: 0.95rem; }
  @media (max-width: 1024px) { .card-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) { .hero-page h1 { font-size: 2.25rem; } .card-grid { grid-template-columns: 1fr; } .cta-banner { flex-direction: column; text-align: center; padding: 2rem; } }
</style>
