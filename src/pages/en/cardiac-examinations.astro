---
import Layout from '../../layouts/Layout.astro';

const exams = [
  { title: 'Electrocardiogram (ECG)', icon: '/images/svg/examens/Electrocardiogramme.svg', text: "A quick, painless examination that reveals a great deal about the electrical activity of your heart. Discover what a simple ECG can uncover." },
  { title: 'Echocardiography', icon: '/images/svg/examens/Ecocardiografia.svg', text: "Watching your own heart beat in real time. Echocardiography — cardiac ultrasound — is a window onto its structure and pumping function." },
  { title: 'Exercise testing', icon: '/images/svg/examens/Ergometria.svg', text: "How does your heart respond to exertion? The bicycle stress test can detect abnormalities that only appear under physical stress." },
  { title: 'Pacemaker', icon: '/images/svg/examens/Marcapasos.svg', text: "When the heartbeat is too slow or dangerously fast, modern implantable devices can take over to protect your heart." },
  { title: 'Laboratory', icon: '/images/svg/examens/Laboratorio.svg', text: "A simple blood test can reveal crucial information about your cardiovascular health, from risk factors to markers of cardiac distress." },
  { title: 'Cardiac MRI', icon: '/images/svg/examens/Resonancia-magnetica.svg', text: "Cutting-edge imaging for unrivalled precision. Discover when cardiac MRI is used to analyse the heart muscle in detail." },
  { title: 'Holter and R-test', icon: '/images/svg/examens/Holter-y-prueba.svg', text: "Some rhythm disorders are subtle and intermittent. The Holter monitor or R-Test captures them over 24 hours or more for a precise diagnosis." },
];
---

<Layout title="Cardiac Examinations — Follow-up in Sion" description="ECG, echocardiography, exercise testing, cardiac MRI, Holter: discover the cardiac examinations offered by Dr Delhasse." lang="en">

  <section class="hero-page">
    <div class="container">
      <h1>Cardiac <span class="text-primary">Examinations</span></h1>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="card-grid">
        {exams.map((e) => (
          <div class="card">
            <img src={e.icon} alt={e.title} class="card__icon" loading="lazy" />
            <h3>{e.title}</h3>
            <p>{e.text}</p>
          </div>
        ))}
      </div>
      <div class="text-center" style="margin-top: 3rem;">
        <a href="/en/contact" class="btn btn--primary">Book an appointment</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .hero-page { background: linear-gradient(135deg, var(--color-navy) 0%, #1a3d6d 100%); padding: 6rem 0 4rem; color: var(--color-white); }
  .hero-page h1 { color: var(--color-white); font-size: 2.75rem; }
  .card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2rem; }
  .card { background: var(--color-white); border-radius: 8px; padding: 2rem; box-shadow: 0 2px 12px rgba(0,0,0,0.06); transition: all 0.3s ease; border-left: 3px solid transparent; }
  .card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.1); border-left-color: var(--color-primary); }
  .card__icon { width: 56px; height: 56px; margin-bottom: 1.25rem; }
  .card h3 { margin-bottom: 0.75rem; font-size: 1.15rem; }
  .card p { font-size: 0.95rem; line-height: 1.6; }
</style>
