---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="Request an Appointment — Dr Delhasse" description="Book an appointment with Dr Delhasse, FMH cardiologist at CIC Clinic in Saxon." lang="en">

  <section class="hero-page">
    <div class="container">
      <h1>Request an <span class="text-primary">Appointment</span></h1>
    </div>
  </section>

  <section class="section">
    <div class="container form-container">
      <nav class="form-tabs">
        <a href="/en/contact/request-appointment" class="form-tab active">Appointment</a>
        <a href="/en/contact/simple-medical-question" class="form-tab">Medical question</a>
        <a href="/en/contact/medical-collaboration" class="form-tab">Collaboration</a>
      </nav>

      <form name="appointment-en" method="POST" data-netlify="true" enctype="multipart/form-data" class="contact-form">
        <input type="hidden" name="form-name" value="appointment-en" />
        <div class="form-grid">
          <div class="form-group">
            <label for="firstname">First name</label>
            <input type="text" id="firstname" name="firstname" />
          </div>
          <div class="form-group">
            <label for="lastname">Last name <span class="required">*</span></label>
            <input type="text" id="lastname" name="lastname" required />
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" />
          </div>
          <div class="form-group">
            <label for="phone">Phone</label>
            <input type="tel" id="phone" name="phone" />
          </div>
        </div>
        <div class="form-group">
          <label for="subject">Subject</label>
          <input type="text" id="subject" name="subject" />
        </div>
        <div class="form-group">
          <label for="file">Attach a file</label>
          <input type="file" id="file" name="file" />
        </div>
        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="6"></textarea>
        </div>
        <button type="submit" class="btn btn--primary">Send</button>
      </form>
    </div>
  </section>

</Layout>

<style>
  .hero-page { background: linear-gradient(135deg, var(--color-navy) 0%, #1a3d6d 100%); padding: 6rem 0 4rem; color: var(--color-white); }
  .hero-page h1 { color: var(--color-white); font-size: 2.75rem; }
  .form-container { max-width: 700px; }
  .form-tabs { display: flex; gap: 0; margin-bottom: 2rem; border-bottom: 2px solid var(--color-gray-light); }
  .form-tab { padding: 0.75rem 1.5rem; text-decoration: none; color: var(--color-gray); font-weight: 600; border-bottom: 2px solid transparent; margin-bottom: -2px; transition: all 0.3s; }
  .form-tab:hover, .form-tab.active { color: var(--color-primary); border-bottom-color: var(--color-primary); }
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-group { margin-bottom: 1.25rem; }
  .form-group label { display: block; margin-bottom: 0.5rem; font-weight: 600; font-size: 0.9rem; color: var(--color-navy); }
  .form-group input, .form-group textarea { width: 100%; padding: 0.75rem 1rem; border: 1px solid #ddd; border-radius: 6px; font-size: 0.95rem; transition: border-color 0.3s; }
  .form-group input:focus, .form-group textarea:focus { outline: none; border-color: var(--color-primary); }
  .required { color: var(--color-primary); }
  @media (max-width: 768px) { .form-grid { grid-template-columns: 1fr; } .hero-page h1 { font-size: 2rem; } .form-tabs { flex-wrap: wrap; } .form-tab { font-size: 0.85rem; padding: 0.5rem 1rem; } }
</style>
