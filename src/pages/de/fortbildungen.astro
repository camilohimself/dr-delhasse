---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
---

<Layout title="Fortbildungen — Engagement von Dr. Delhasse in der Kardiologie" description="Dr. Delhasse nimmt aktiv an der medizinischen Fortbildung in der Kardiologie teil. Vorträge, Konferenzen und Austausch im ganzen Wallis." lang="de">

  <section class="hero-page">
    <div class="container">
      <Breadcrumb items={[{label:'Startseite', href:'/de'}, {label:'Fortbildungen'}]} />
      <h1><span class="text-primary">Fortbildungen</span></h1>
      <p class="hero-sub">Dr. Delhasse nimmt aktiv an der medizinischen Fortbildung in der Kardiologie teil. Vorträge, Konferenzen und Austausch im ganzen Wallis.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid--2 formations-grid">
        <div class="formation-card">
          <img src="/images/formation-irm.webp" alt="Die verborgene Kraft des Kardio-MRT" loading="lazy" />
          <div class="formation-card__body">
            <h2>Die verborgene Kraft des Kardio-MRT</h2>
            <p>Entdecken Sie, wie das Kardio-MRT die Diagnose und Überwachung von Herz-Kreislauf-Erkrankungen revolutioniert.</p>
            <a href="/de/kontakt" class="btn btn--primary">Mehr erfahren</a>
          </div>
        </div>
        <div class="formation-card">
          <img src="/images/formation-vitalite.webp" alt="Programm Herz und Vitalität" loading="lazy" />
          <div class="formation-card__body">
            <h2>Programm Herz und Vitalität</h2>
            <p>Ein umfassendes Programm für die tägliche Herzgesundheit, das körperliche Aktivität und medizinische Betreuung verbindet.</p>
            <a href="/de/kontakt" class="btn btn--primary">Mehr erfahren</a>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .hero-page { background: linear-gradient(135deg, var(--color-navy) 0%, #1a3d6d 100%); padding: 6rem 0 4rem; color: var(--color-white); }
  .hero-page h1 { color: var(--color-white); font-size: 2.75rem; }
  .hero-sub { color: rgba(255,255,255,0.75); font-size: 1.15rem; margin-top: 1rem; max-width: 650px; }
  .formations-grid { margin-top: 1rem; }
  .formation-card { background: var(--color-white); border-radius: 8px; overflow: hidden; box-shadow: 0 2px 16px rgba(0,0,0,0.08); transition: all 0.3s ease; }
  .formation-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
  .formation-card img { width: 100%; height: 250px; object-fit: cover; }
  .formation-card__body { padding: 2rem; }
  .formation-card h2 { font-size: 1.4rem; margin-bottom: 1rem; }
  .formation-card p { margin-bottom: 1.5rem; }
  @media (max-width: 768px) { .hero-page h1 { font-size: 2rem; } }
</style>
