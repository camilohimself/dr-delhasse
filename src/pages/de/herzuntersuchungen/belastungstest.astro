  lang="de"
  alternates={{ fr: '/examens-cardiologiques/ergometrie', en: '/en/cardiac-examinations/exercise-stress-test', de: '/de/herzuntersuchungen/belastungstest' }}
  pageTitleHtml="<span class='text-primary'>Ergometrie</span>"
  subtitle="Der kardiale Belastungstest"
