<DetailLayout
  title="Präoperative Abklärung — Dr. Delhasse"
  description="Kardiologische Abklärung vor Herzoperationen und nicht-kardialen Eingriffen."
  lang="de"
  alternates={{ fr: '/domaines-dexpertise/bilan-preoperatoire', en: '/en/areas-of-expertise/preoperative-assessment', de: '/de/fachgebiete/praeoperative-abklaerung' }}
  pageTitleHtml="Präoperative <span class='text-primary'>Abklärung</span>"
  subtitle="Ihre kardiale Sicherheit vor jedem Eingriff"
  heroBg="/images/collaboration.webp"
  heroImage="/images/detail/bilan-preoperatoire.webp"
  heroImageAlt="Präoperative Abklärung"
