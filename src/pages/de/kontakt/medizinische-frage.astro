---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="Medizinische Frage — Dr. Delhasse" description="Stellen Sie eine einfache medizinische Frage an Dr. Delhasse, FMH-Kardiologe." lang="de">
  <section class="hero-page"><div class="container"><h1>Medizinische <span class="text-primary">Frage</span></h1></div></section>
  <section class="section"><div class="container form-container">
    <nav class="form-tabs">
      <a href="/de/kontakt/terminanfrage" class="form-tab">Termin</a>
      <a href="/de/kontakt/medizinische-frage" class="form-tab active">Medizinische Frage</a>
      <a href="/de/kontakt/zusammenarbeit" class="form-tab">Zusammenarbeit</a>
    </nav>
    <form name="frage-de" method="POST" data-netlify="true">
      <input type="hidden" name="form-name" value="frage-de" />
      <div class="form-grid">
        <div class="form-group"><label for="vorname">Vorname</label><input type="text" id="vorname" name="vorname" /></div>
        <div class="form-group"><label for="nachname">Nachname <span class="required">*</span></label><input type="text" id="nachname" name="nachname" required /></div>
      </div>
      <div class="form-group"><label for="email">E-Mail</label><input type="email" id="email" name="email" /></div>
      <div class="form-group"><label for="betreff">Betreff</label><input type="text" id="betreff" name="betreff" /></div>
      <div class="form-group"><label for="nachricht">Nachricht</label><textarea id="nachricht" name="nachricht" rows="6"></textarea></div>
      <button type="submit" class="btn btn--primary">Senden</button>
    </form>
  </div></section>
</Layout>
<style>
  .hero-page { background: linear-gradient(135deg, var(--color-navy) 0%, #1a3d6d 100%); padding: 6rem 0 4rem; color: var(--color-white); }
  .hero-page h1 { color: var(--color-white); font-size: 2.75rem; }
  .form-container { max-width: 700px; }
  .form-tabs { display: flex; gap: 0; margin-bottom: 2rem; border-bottom: 2px solid var(--color-gray-light); }
  .form-tab { padding: 0.75rem 1.5rem; text-decoration: none; color: var(--color-gray); font-weight: 600; border-bottom: 2px solid transparent; margin-bottom: -2px; transition: all 0.3s; }
  .form-tab:hover, .form-tab.active { color: var(--color-primary); border-bottom-color: var(--color-primary); }
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-group { margin-bottom: 1.25rem; }
  .form-group label { display: block; margin-bottom: 0.5rem; font-weight: 600; font-size: 0.9rem; color: var(--color-navy); }
  .form-group input, .form-group textarea { width: 100%; padding: 0.75rem 1rem; border: 1px solid #ddd; border-radius: 6px; font-size: 0.95rem; }
  .form-group input:focus, .form-group textarea:focus { outline: none; border-color: var(--color-primary); }
  .required { color: var(--color-primary); }
  @media (max-width: 768px) { .form-grid { grid-template-columns: 1fr; } .hero-page h1 { font-size: 2rem; } .form-tabs { flex-wrap: wrap; } .form-tab { font-size: 0.85rem; } }
</style>
