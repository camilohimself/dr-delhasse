<DetailLayout
  title="Brustschmerzen: Wann sollten Sie sich Sorgen machen? — Dr. Delhasse"
  description="Nicht alle Brustschmerzen sind kardialen Ursprungs. Lernen Sie die Warnsignale zu erkennen."
  lang="de"
  alternates={{ fr: '/symptomes/douleurs-thoraciques', en: '/en/symptoms/chest-pain', de: '/de/symptome/brustschmerzen' }}
  pageTitleHtml="<span class='text-primary'>Brustschmerzen</span>"
  subtitle="Wann sollten Sie sich Sorgen machen?"
