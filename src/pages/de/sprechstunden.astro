---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
---

<Layout title="Ihr Herz & Sie — Kardiologische Sprechstunden" description="Symptome, Fachgebiete und Herzuntersuchungen. Ein umfassender Ansatz zur Untersuchung, Diagnose und Behandlung von Herzerkrankungen." lang="de">

  <section class="hero-page">
    <div class="container">
      <Breadcrumb items={[{label:'Startseite', href:'/de'}, {label:'Sprechstunden'}]} />
      <h1>Ihr Herz <span class="text-primary">&</span> Sie</h1>
      <p class="hero-sub">Ein umfassender Ansatz zur Untersuchung, Diagnose und Behandlung von Herzerkrankungen.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid--3">
        <a href="/de/symptome" class="hub-card">
          <img src="/images/collaboration.webp" alt="Symptome" loading="lazy" />
          <div class="hub-card__body">
            <h2>Symptome</h2>
            <p>Entdecken Sie die klinischen Zeichen, die eine kardiologische Konsultation erfordern.</p>
            <span class="hub-card__link">Mehr erfahren →</span>
          </div>
        </a>
        <a href="/de/fachgebiete" class="hub-card">
          <img src="/images/question-medicale.webp" alt="Fachgebiete" loading="lazy" />
          <div class="hub-card__body">
            <h2>Fachgebiete</h2>
            <p>Spezialisierungen und Herzerkrankungen, die von Dr. Delhasse behandelt werden.</p>
            <span class="hub-card__link">Mehr erfahren →</span>
          </div>
        </a>
        <a href="/de/herzuntersuchungen" class="hub-card">
          <img src="/images/demande-rdv.webp" alt="Herzuntersuchungen" loading="lazy" />
          <div class="hub-card__body">
            <h2>Herzuntersuchungen</h2>
            <p>EKG, Echokardiografie, Belastungstest und weitere diagnostische Verfahren.</p>
            <span class="hub-card__link">Mehr erfahren →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .hero-page { background: linear-gradient(135deg, var(--color-navy) 0%, #1a3d6d 100%); padding: 6rem 0 4rem; color: var(--color-white); }
  .hero-page h1 { color: var(--color-white); font-size: 2.75rem; }
  .hero-sub { color: rgba(255,255,255,0.75); font-size: 1.15rem; margin-top: 1rem; }
  .hub-card { display: block; background: var(--color-white); border-radius: 8px; overflow: hidden; box-shadow: 0 2px 16px rgba(0,0,0,0.08); transition: all 0.3s ease; text-decoration: none; }
  .hub-card:hover { transform: translateY(-6px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
  .hub-card img { width: 100%; height: 220px; object-fit: cover; }
  .hub-card__body { padding: 2rem; }
  .hub-card h2 { font-size: 1.4rem; margin-bottom: 0.75rem; }
  .hub-card p { font-size: 0.95rem; margin-bottom: 1rem; }
  .hub-card__link { color: var(--color-primary); font-weight: 600; font-size: 0.9rem; }
  @media (max-width: 768px) { .hero-page h1 { font-size: 2rem; } }
</style>
