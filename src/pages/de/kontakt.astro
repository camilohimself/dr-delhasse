---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
---

<Layout title="Kontaktieren Sie uns — Dr. Sébastien Delhasse" description="Vereinbaren Sie einen Kardiologie-Termin an der Klinik CIC Saxon. Kontakt per Telefon oder Formular." lang="de">

  <section class="hero-page">
    <div class="container">
      <Breadcrumb items={[{label:'Startseite', href:'/de'}, {label:'Kontakt'}]} />
      <h1>Kontaktieren Sie <span class="text-primary">uns</span></h1>
      <p class="hero-sub">Vereinbaren Sie einfach einen Termin für eine Sprechstunde in der Praxis oder eine Telekonsultation.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid--3 contact-cards">
        <div class="contact-card">
          <div class="contact-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
          </div>
          <h3>Terminanfrage</h3>
          <p>Vereinbaren Sie einfach einen Termin für eine Sprechstunde in der Praxis oder eine Telekonsultation.</p>
        </div>
        <div class="contact-card">
          <div class="contact-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </div>
          <h3>Kurze medizinische Frage</h3>
          <p>Stellen Sie eine kurze Frage und erhalten Sie eine schnelle und professionelle Antwort.</p>
        </div>
        <div class="contact-card">
          <div class="contact-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" x2="19" y1="8" y2="14"/><line x1="22" x2="16" y1="11" y2="11"/></svg>
          </div>
          <h3>Zusammenarbeit oder Sonstiges</h3>
          <p>Für Kooperationsanfragen, Vorträge oder andere spezifische Anliegen.</p>
        </div>
      </div>

      <div class="contact-form-wrapper">
        <h2>Senden Sie uns eine <span class="text-primary">Nachricht</span></h2>
        <form class="contact-form" id="contact-form" name="contact-de" method="POST" action="mailto:sebastien.delhasse@hotmail.com" enctype="text/plain">
          <p style="display:none;"><label>Nicht ausfüllen: <input name="bot-field" /></label></p>
          <div class="form-row">
            <div class="form-group">
              <label for="name">Vollständiger Name *</label>
              <input type="text" id="name" name="name" required />
            </div>
            <div class="form-group">
              <label for="email">E-Mail *</label>
              <input type="email" id="email" name="email" required />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="phone">Telefon</label>
              <input type="tel" id="phone" name="phone" />
            </div>
            <div class="form-group">
              <label for="subject">Betreff *</label>
              <select id="subject" name="subject" required>
                <option value="">Wählen...</option>
                <option value="termin">Terminanfrage</option>
                <option value="frage">Kurze medizinische Frage</option>
                <option value="zusammenarbeit">Zusammenarbeit oder Sonstiges</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label for="message">Nachricht *</label>
            <textarea id="message" name="message" rows="5" required></textarea>
          </div>
          <button type="submit" class="btn btn--primary">Nachricht senden</button>
        </form>
        <div class="form-success" id="form-success" style="display:none;">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <h3>Nachricht gesendet!</h3>
          <p>Wir melden uns schnellstmöglich bei Ihnen.</p>
        </div>
      </div>

      <div class="contact-info grid grid--3">
        <div class="info-card">
          <h4>Telefon</h4>
          <a href="tel:+41277434059">+41 27 743 40 59</a>
        </div>
        <div class="info-card">
          <h4>Adresse</h4>
          <p>Klinik CIC Saxon<br />Rte du Léman 29<br />1907 Saxon</p>
        </div>
        <div class="info-card">
          <h4>Öffnungszeiten</h4>
          <p>Montag – Freitag<br />09:00 – 17:00</p>
        </div>
      </div>

      <!-- Google Maps -->
      <div class="map-wrapper">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2756.8!2d7.1847!3d46.1467!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x478edc8b0a0a0001%3A0x0!2sClinique%20CIC%20Saxon%2C%20Rte%20du%20L%C3%A9man%2029%2C%201907%20Saxon!5e0!3m2!1sde!2sch!4v1"
          width="100%"
          height="400"
          style="border:0; border-radius: 8px;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Klinik CIC Saxon — Dr. Delhasse"
        ></iframe>
      </div>
    </div>
  </section>

</Layout>

<style>
  .hero-page { background: linear-gradient(135deg, var(--color-navy) 0%, #1a3d6d 100%); padding: 6rem 0 4rem; color: var(--color-white); }
  .hero-page h1 { color: var(--color-white); font-size: 2.75rem; }
  .hero-sub { color: rgba(255,255,255,0.75); font-size: 1.15rem; margin-top: 1rem; }
  .contact-cards { margin-bottom: 4rem; }
  .contact-card { background: var(--color-gray-light); padding: 2.5rem 2rem; border-radius: 8px; text-align: center; }
  .contact-card__icon { color: var(--color-primary); margin-bottom: 1.25rem; }
  .contact-card h3 { margin-bottom: 0.75rem; }
  .contact-card p { font-size: 0.95rem; }
  .contact-form-wrapper { max-width: 700px; margin: 0 auto 4rem; }
  .contact-form-wrapper h2 { margin-bottom: 2rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem; }
  .form-group { display: flex; flex-direction: column; }
  .form-group label { font-size: 0.9rem; font-weight: 600; color: var(--color-navy); margin-bottom: 0.5rem; }
  .form-group textarea { resize: vertical; }
  .contact-form .form-group:last-of-type { margin-bottom: 1.5rem; }
  .contact-info { padding-top: 3rem; border-top: 1px solid #eee; }
  .info-card { text-align: center; }
  .info-card h4 { margin-bottom: 0.75rem; color: var(--color-navy); }
  .info-card a { color: var(--color-primary); font-size: 1.15rem; font-weight: 600; }
  .info-card p { font-size: 0.95rem; }
  .map-wrapper { margin-top: 3rem; }
  @media (max-width: 768px) { .hero-page h1 { font-size: 2rem; } .form-row { grid-template-columns: 1fr; } .contact-form .btn { width: 100%; } .map-wrapper iframe { height: 250px; } }
</style>
