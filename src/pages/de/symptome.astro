---
import Layout from '../../layouts/Layout.astro';

const symptome = [
  { title: 'Brustschmerzen', icon: '/images/svg/symptomes/Dolor-en-el-pecho.svg', text: 'Nicht alle Brustschmerzen sind kardialen Ursprungs, aber einige sind Warnsignale, die nie ignoriert werden sollten. Lernen Sie, sie zu erkennen.' },
  { title: 'Ohnmacht / Schwindel', icon: '/images/svg/symptomes/Malestar.svg', text: 'Ein einfacher Schwindelanfall mag harmlos erscheinen, kann aber auch das erste Anzeichen einer Herzerkrankung sein. Unterschätzen Sie dieses Symptom nicht.' },
  { title: 'Herzrasen', icon: '/images/svg/symptomes/Palpitaciones.svg', text: 'Ihr Herz rast? Erfahren Sie, wann einfaches Herzrasen eine Rhythmusstörung verbergen kann, die ärztliche Aufmerksamkeit erfordert.' },
  { title: 'Müdigkeit', icon: '/images/svg/symptomes/Fatiga.svg', text: 'Anhaltende, unerklärliche Müdigkeit ist nicht normal. Sie kann direkt mit der Gesundheit Ihres Herzens zusammenhängen. Verstehen Sie warum.' },
  { title: 'Dyspnoe', icon: '/images/svg/symptomes/Disnea.svg', text: 'Kurzatmigkeit ist nicht immer ein Lungenproblem. Erfahren Sie, wann Ihre Atmung Sie auf die Gesundheit Ihres Herzens aufmerksam macht.' },
  { title: 'Unregelmässiger Herzrhythmus', icon: '/images/svg/symptomes/Arritmia-1.svg', text: 'Hat Ihre Smartwatch einen unregelmässigen Rhythmus erkannt? Erfahren Sie, was diese Warnungen bedeuten und wann die Meinung eines Kardiologen unverzichtbar ist.' },
  { title: 'Beinödeme', icon: '/images/svg/symptomes/Edema-en-la-pierna.svg', text: 'Geschwollene Beine sind nicht nur ein Komfortproblem. Erfahren Sie, wie sie ein sichtbares Zeichen einer Herzinsuffizienz sein können.' },
];
---

<Layout title="Häufige Herzsymptome — Dr. Delhasse" description="Brustschmerzen, Herzrasen, Müdigkeit, Dyspnoe: Entdecken Sie die Symptome, die eine kardiologische Konsultation erfordern." lang="de">

  <section class="hero-page">
    <div class="container">
      <h1><span class="text-primary">Symptome</span></h1>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="card-grid">
        {symptome.map((s) => (
          <div class="card">
            <img src={s.icon} alt={s.title} class="card__icon" loading="lazy" />
            <h3>{s.title}</h3>
            <p>{s.text}</p>
          </div>
        ))}
      </div>
      <div class="text-center" style="margin-top: 3rem;">
        <a href="/de/kontakt" class="btn btn--primary">Termin vereinbaren</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .hero-page { background: linear-gradient(135deg, var(--color-navy) 0%, #1a3d6d 100%); padding: 6rem 0 4rem; color: var(--color-white); }
  .hero-page h1 { color: var(--color-white); font-size: 2.75rem; }
  .card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2rem; }
  .card { background: var(--color-white); border-radius: 8px; padding: 2rem; box-shadow: 0 2px 12px rgba(0,0,0,0.06); transition: all 0.3s ease; border-left: 3px solid transparent; }
  .card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.1); border-left-color: var(--color-primary); }
  .card__icon { width: 56px; height: 56px; margin-bottom: 1.25rem; }
  .card h3 { margin-bottom: 0.75rem; font-size: 1.15rem; }
  .card p { font-size: 0.95rem; line-height: 1.6; }
</style>
