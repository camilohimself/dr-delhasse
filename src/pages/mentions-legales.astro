<style>
  .hero-page {
    background: linear-gradient(135deg, var(--color-navy) 0%, #1a3d6d 100%);
    padding: 6rem 0 4rem;
    color: var(--color-white);
  }

  .hero-page h1 { color: var(--color-white); font-size: 2.75rem; }

  .legal-content {
    max-width: 800px;
  }

  .legal-content h2 {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    font-size: 1.25rem;
  }

  .legal-content ul {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .legal-content li {
    list-style: disc;
    margin-bottom: 0.5rem;
    color: var(--color-gray);
    font-size: 0.95rem;
  }

  .legal-content a {
    color: var(--color-primary);
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .hero-page h1 { font-size: 2rem; }
  }
</style>
