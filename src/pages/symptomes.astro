---
import Layout from '../layouts/Layout.astro';

const symptomes = [
  {
    title: 'Douleurs thoraciques',
    icon: '/images/svg/symptomes/Dolor-en-el-pecho.svg',
    text: "Toutes les douleurs thoraciques ne sont pas d'origine cardiaque, mais certaines sont des signaux d'alerte à ne jamais ignorer. Apprenez à les reconnaître.",
    href: '/symptomes/douleurs-thoraciques',
  },
  {
    title: 'Malaise',
    icon: '/images/svg/symptomes/Malestar.svg',
    text: "Un simple vertige peut sembler anodin, mais il peut aussi être le premier signe d'un trouble cardiaque. Ne sous-estimez pas ce symptôme.",
    href: '/symptomes/malaise',
  },
  {
    title: 'Palpitations',
    icon: '/images/svg/symptomes/Palpitaciones.svg',
    text: "Votre cœur s'emballe ? Découvrez quand de simples palpitations peuvent cacher un trouble du rythme nécessitant une attention médicale.",
    href: '/symptomes/palpitations',
  },
  {
    title: 'Fatigue',
    icon: '/images/svg/symptomes/Fatiga.svg',
    text: "Une fatigue persistante et inexpliquée n'est pas normale. Elle peut être directement liée à la santé de votre cœur. Comprenez pourquoi.",
    href: '/symptomes/fatigue',
  },
  {
    title: 'Dyspnée',
    icon: '/images/svg/symptomes/Disnea.svg',
    text: "L'essoufflement n'est pas toujours un problème pulmonaire. Découvrez quand votre souffle vous alerte sur la santé de votre cœur.",
    href: '/symptomes/dyspnee',
  },
  {
    title: 'Rythme cardiaque irrégulier',
    icon: '/images/svg/symptomes/Arritmia-1.svg',
    text: "Votre montre connectée a détecté un rythme irrégulier ? Apprenez ce que ces alertes signifient et quand l'avis d'un cardiologue est indispensable.",
    href: '/symptomes/rythme-cardiaque-irregulier',
  },
  {
    title: 'Œdèmes des jambes',
    icon: '/images/svg/symptomes/Edema-en-la-pierna.svg',
    text: "Des jambes gonflées ne sont pas qu'un problème de confort. Découvrez comment elles peuvent être le signe visible d'une insuffisance cardiaque.",
    href: '/symptomes/oedemes-des-jambes',
  },
];
---

<Layout title="Symptômes cardiaques fréquents — Dr Delhasse" description="Douleurs thoraciques, palpitations, fatigue, dyspnée : découvrez les symptômes qui nécessitent une consultation cardiologique." lang="fr">

  <section class="hero-page">
    <div class="hero-page__bg" aria-hidden="true"></div>
    <div class="container hero-page__content">
      <p class="hero-page__label">Le Cœur & vous</p>
      <h1>Symptômes</h1>
      <p class="hero-page__sub">Reconnaître les signaux que votre cœur vous envoie</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="card-grid">
        {symptomes.map((s, i) => (
          <a href={s.href} class="card">
            <div class="card__icon-wrap">
              <img src={s.icon} alt={s.title} class="card__icon" loading="lazy" width="40" height="40" />
            </div>
            <h3 class="card__title">{s.title}</h3>
            <p class="card__text">{s.text}</p>
            <span class="card__link">
              En savoir plus
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 16 16 12 12 8"/><line x1="8" x2="16" y1="12" y2="12"/></svg>
            </span>
          </a>
        ))}
      </div>

      <div class="cta-banner">
        <div class="cta-banner__text">
          <h2>Un symptôme vous inquiète ?</h2>
          <p>N'attendez pas. Prenez rendez-vous pour une consultation cardiologique.</p>
        </div>
        <a href="/contact" class="btn btn--primary">Prendre rendez-vous</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .hero-page {
    background: linear-gradient(135deg, var(--color-navy) 0%, #0e2240 50%, #1a3d6d 100%);
    padding: 7rem 0 4rem;
    color: var(--color-white);
    position: relative;
    overflow: hidden;
  }

  .hero-page__bg {
    position: absolute;
    inset: 0;
    background-image: url('/images/cardiologie-med-interne.webp');
    background-size: cover;
    background-position: center;
    opacity: 0.12;
  }

  .hero-page__content {
    position: relative;
    z-index: 2;
  }

  .hero-page__label {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-primary);
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .hero-page h1 {
    color: var(--color-white);
    font-size: 3rem;
    margin-bottom: 0.75rem;
  }

  .hero-page__sub {
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.1rem;
    max-width: 500px;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .card {
    display: flex;
    flex-direction: column;
    background: var(--color-white);
    border-radius: var(--radius-md);
    padding: 2rem;
    box-shadow: var(--shadow-sm);
    transition: all 0.3s ease;
    text-decoration: none;
    border: 1px solid transparent;
    position: relative;
  }

  .card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: rgba(220, 27, 26, 0.15);
  }

  .card__icon-wrap {
    width: 72px;
    height: 72px;
    background: var(--color-gray-light);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    transition: all 0.3s ease;
  }

  .card:hover .card__icon-wrap {
    background: var(--color-primary-light);
  }

  .card__icon {
    width: 40px;
    height: 40px;
  }

  .card__title {
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    font-weight: 700;
  }

  .card__text {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-gray);
    flex: 1;
  }

  .card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.25rem;
    padding: 0.5rem 1rem;
    background: var(--color-primary);
    color: var(--color-white);
    border-radius: 50px;
    font-size: 0.8rem;
    font-weight: 600;
    transition: all 0.3s ease;
    align-self: flex-start;
  }

  .card:hover .card__link {
    background: var(--color-primary-dark);
    transform: translateX(4px);
  }

  /* CTA Banner */
  .cta-banner {
    margin-top: 4rem;
    background: var(--color-navy);
    border-radius: var(--radius-lg);
    padding: 3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .cta-banner h2 {
    color: var(--color-white);
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .cta-banner p {
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
    font-size: 0.95rem;
  }

  @media (max-width: 1024px) {
    .card-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .hero-page h1 { font-size: 2.25rem; }
    .card-grid { grid-template-columns: 1fr; }
    .cta-banner {
      flex-direction: column;
      text-align: center;
      padding: 2rem;
    }
  }
</style>
