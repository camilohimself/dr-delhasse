<DetailLayout
  title="Échocardiographie — Dr Delhasse, Cardiologue"
  description="L'échocardiographie permet de visualiser le cœur en temps réel. Examen réalisé par le Dr Delhasse en consultation."
  lang="fr"
  alternates={{ fr: '/examens-cardiologiques/echocardiographie', en: '/en/cardiac-examinations/echocardiography', de: '/de/herzuntersuchungen/echokardiographie' }}
  pageTitleHtml="<span class='text-primary'>Échocardiographie</span>"
  subtitle="L'ultrason du cœur"
  heroBg="/images/demande-rdv.webp"
  heroImage="/images/detail/echocardiographie.webp"
  heroImageAlt="Échocardiographie"
  icon="/images/svg/examens/Ecocardiografia.svg"
  iconAlt="Échocardiographie"
